<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="cmasacoTS3.Views.vLogin"
             Title="vLogin">
    
    
    <VerticalStackLayout Spacing="0" VerticalOptions="Fill">


        <Border Margin="30,80,30,40" 
                Padding="25" 
                BackgroundColor="#CCFFFFFF" 
                VerticalOptions="Center">      
            
            <VerticalStackLayout Spacing="20">
                <!-- Logo o Ícono -->
                <Image Source="https://sige.uisrael.edu.ec/imagenes/LogosUISRAEL/emprende.png"
                       HeightRequest="100" 
                       HorizontalOptions="Center" 
                       Margin="0,0,0,10"/>

                <Label Text="Inicia Sesión Para Continuar" 
                       FontSize="28" 
                       FontAttributes="Bold" 
                       TextColor="#2c5364" 
                       HorizontalOptions="Center" />         

                <Entry  x:Name="txtUsuario" 
                        Placeholder="Usuario" 
                        PlaceholderColor="Gray"
                        TextColor="Black"
                        HeightRequest="45"/>                    

                <Entry x:Name="txtContrasena" 
                       Placeholder="Contraseña" 
                       IsPassword="True" 
                       PlaceholderColor="Gray"
                       TextColor="Black"
                       HeightRequest="45"/>
                
                <Button x:Name="btnIniciar" 
                        Text="INICIAR SESIÓN" 
                        Clicked="btnIniciar_Clicked"
                        BackgroundColor="#2B88D9" 
                        TextColor="White" 
                        HeightRequest="50" 
                        CornerRadius="25"
                        FontAttributes="Bold"
                        Margin="0,10,0,0"/>                
            </VerticalStackLayout>
        </Border>        
    </VerticalStackLayout>
</ContentPage>